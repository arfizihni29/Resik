# ==========================================
# ENV Variables (Contoh)
# Copy file ini menjadi .env dan isi dengan secret.
# ==========================================

# 1. DATABASE LOCAL
DB_HOST_LOCAL=localhost
DB_NAME_LOCAL=sampah_db
DB_USER_LOCAL=root
DB_PASS_LOCAL=

# 2. DATABASE PRODUCTION (Hosting)
DB_HOST_PROD=localhost
DB_NAME_PROD=your_prod_db
DB_USER_PROD=your_prod_user
DB_PASS_PROD=your_prod_password

# 3. AI CONFIG
AI_DEFAULT_KEY=YOUR_DEFAULT_API_KEY
AI_KEY_1=
AI_KEY_2=
AI_KEY_3=
AI_KEY_4=
AI_KEY_5=
AI_KEY_6=
AI_KEY_7=
AI_KEY_8=

# 4. GOOGLE OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
